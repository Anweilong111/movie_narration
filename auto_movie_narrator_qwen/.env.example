APP_NAME=Auto Movie Narrator Qwen
APP_MOCK_MODE=true
APP_WORKDIR=workdir
APP_PUBLIC_BASE_URL=http://127.0.0.1:8000

DASHSCOPE_API_KEY=
DASHSCOPE_COMPAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_HTTP_BASE_URL=https://dashscope.aliyuncs.com/api/v1

QWEN_TEXT_MODEL=qwen3.7-max
QWEN_VISION_MODEL=qwen3.7-plus
QWEN_TTS_MODEL=qwen3-tts-instruct-flash
QWEN_TTS_INSTRUCT_MODEL=qwen3-tts-instruct-flash
QWEN_TTS_VC_MODEL=qwen3-tts-vc-2026-01-22
QWEN_ASR_MODEL=qwen3-asr-flash-filetrans
QWEN_REQUEST_TIMEOUT_SECONDS=120
QWEN_MAX_RETRIES=2
QWEN_TTS_POLL_INTERVAL_SECONDS=2
QWEN_TTS_MAX_WAIT_SECONDS=300
QWEN_ASR_POLL_INTERVAL_SECONDS=2
QWEN_ASR_MAX_WAIT_SECONDS=1800
QWEN_ASR_LANGUAGE_HINTS=zh,en

DEFAULT_MALE_VOICE=Ethan
DEFAULT_FEMALE_VOICE=Cherry

SCENE_DETECTOR=transnetv2
TRANSNETV2_COMMAND=/data1/movie_narration/auto_movie_narrator_qwen/scripts/run_transnetv2.sh
TRANSNETV2_MIN_SHOT_SECONDS=0.75
TRANSNETV2_TARGET_SCENE_SECONDS=24
TRANSNETV2_MAX_SCENE_SECONDS=48
KEYFRAME_FPS=0.5
VISION_MAX_KEYFRAMES_PER_SCENE=9
VISION_GRID_ENABLED=true
VISION_GRID_ROWS=3
VISION_GRID_COLS=3
SCENE_MIN_SECONDS=30
DEFAULT_TARGET_DURATION=300
DEFAULT_LANGUAGE=zh-CN

FAST_QUALITY_ENABLED=false
FAST_QUALITY_TARGET_SCENE_COUNT=72
FAST_QUALITY_MIN_SCENE_SECONDS=45
FAST_QUALITY_MAX_SCENE_SECONDS=100
FAST_QUALITY_GRID_KEYFRAMES_PER_SCENE=9
FAST_QUALITY_DETAIL_KEYFRAMES_PER_SCENE=3
FAST_QUALITY_LOCAL_SCRIPT_ENABLED=true
VISION_DETAIL_KEYFRAMES_PER_SCENE=9
VISION_CONCURRENCY=1
STORY_CONCURRENCY=1

QUALITY_FIRST_ENABLED=false
TURBO40_ENABLED=false
KEYFRAME_EXTRACTION_MODE=fps
TTS_CONCURRENCY=1
FFMPEG_VIDEO_ENCODER=libx264
NARRATIVE_FORCE_MODEL_SCRIPT=false
NARRATIVE_THEME_REWRITE_ENABLED=true
NARRATIVE_PRESERVE_MODEL_ORDER=true
CLIP_FRAGMENTATION_ENABLED=true
CLIP_FRAGMENT_MIN_SECONDS=2
CLIP_FRAGMENT_MAX_SECONDS=5
CLIP_FRAGMENT_GAP_SECONDS=1
CLIP_FRAGMENT_CONTEXT_SECONDS=18
CLIP_RHYTHM_ENABLED=true
CLIP_RHYTHM_MAX_VISUAL_HOLD_SECONDS=4.2
CLIP_RHYTHM_MIN_VISUAL_CLIP_SECONDS=1.6
CLIP_OPENING_HOOK_ENABLED=true
CLIP_OPENING_HOOK_SECONDS=3.6
FINAL_SPEEDFIT_ENABLED=false
FINAL_SPEEDFIT_TOLERANCE_SECONDS=2
FINAL_VERTICAL_ENABLED=true
FINAL_VERTICAL_WIDTH=1080
FINAL_VERTICAL_HEIGHT=1920
FINAL_VERTICAL_BACKGROUND=black
FINAL_VERTICAL_BLUR_SIGMA=28
FINAL_VERTICAL_SUBTITLE_FONT_FAMILY=Songti SC
FINAL_VERTICAL_SUBTITLE_FONT_SIZE=58
FINAL_VERTICAL_SUBTITLE_MARGIN_V=1320
FINAL_VERTICAL_SUBTITLE_ALIGNMENT=8
FINAL_VERTICAL_SUBTITLE_OUTLINE=4.2
FINAL_VERTICAL_SUBTITLE_SHADOW=0.8
LLM_QUALITY_MODE=full

AUDIO_DIALOGUE_DUCKING_ENABLED=true
AUDIO_BACKGROUND_VOLUME=0.16
AUDIO_DIALOGUE_VOLUME=0.004
AUDIO_NARRATION_VOLUME=1.0
AUDIO_DIALOGUE_DUCKING_PAD_SECONDS=0.28
AUDIO_LOUDNORM_ENABLED=true
AUDIO_LOUDNORM_INTEGRATED_LUFS=-23.0
AUDIO_LOUDNORM_TRUE_PEAK_DB=-2.0
AUDIO_LOUDNORM_LRA=11.0
QUALITY_FREEZE_DETECT_ENABLED=true
QUALITY_FREEZE_DETECT_MIN_SECONDS=4.5
QUALITY_FREEZE_DETECT_SAMPLE_FPS=2
